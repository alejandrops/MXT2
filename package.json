{
  "name": "maxtracker-functional",
  "version": "0.1.0",
  "private": true,
  "description": "Maxtracker — Demo funcional con datos simulados",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
