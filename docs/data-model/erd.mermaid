  }
}}%%

erDiagram

  Organization ||--o{ Account : "tenant"
  Account      ||--o{ Group   : "owns"
  Account      ||--o{ Asset   : "owns"
  Account      ||--o{ Person  : "employs"
  Account      ||--o{ Alarm   : "scoped"

  Group ||--o{ Group : "parent of"
  Group ||--o{ Asset : "contains [ADR-001]"

  Asset ||--o{ Device   : "has"
  Asset ||--o{ Position : "reports"
  Asset ||--o{ Event    : "produces"
  Asset ||--o{ Alarm    : "triggers"

  Person ||--o{ Asset : "drives [snapshot]"
  Person ||--o{ Event : "actor at moment"
  Person ||--o{ Alarm : "actor at moment"

  Organization {
    String   id        PK
    String   name
    String   slug      UK
    DateTime createdAt
  }

  Account {
    String   id              PK
    String   organizationId  FK
    String   name
    String   slug            UK
    Tier     tier
    String   industry
    DateTime createdAt
  }

  Group {
    String   id        PK
    String   accountId FK
    String   parentId  FK
    String   name
    DateTime createdAt
  }

  Asset {
    String       id              PK
    String       accountId       FK
    String       groupId         FK
    String       name
    String       plate           UK
    String       vin             UK
    MobilityType mobilityType
    String       make
    String       model
    Int          year
    AssetStatus  status
    String       currentDriverId FK
    DateTime     createdAt
  }

  Device {
    String   id          PK
    String   assetId     FK
    String   imei        UK
    String   vendor
    String   model
    Boolean  isPrimary
    DateTime lastSeenAt
    DateTime installedAt
  }

  Person {
    String   id               PK
    String   accountId        FK
    String   firstName
    String   lastName
    String   document
    DateTime licenseExpiresAt
    DateTime hiredAt
    Int      safetyScore
  }

  Position {
    String   id         PK
    String   assetId    FK
    DateTime recordedAt
    DateTime receivedAt
    Float    lat
    Float    lng
    Float    speedKmh
    Int      heading
    Boolean  ignition
  }

  Event {
    String    id         PK
    String    assetId    FK
    String    personId   FK
    EventType type
    Severity  severity
    DateTime  occurredAt
    Float     lat
    Float     lng
    Float     speedKmh
    String    metadata
  }

  Alarm {
    String      id          PK
    String      accountId   FK
    String      assetId     FK
    String      personId    FK
    AlarmType   type
    Severity    severity
    AlarmStatus status
    DateTime    triggeredAt
    DateTime    attendedAt
    DateTime    closedAt
    Float       lat
    Float       lng
    String      notes
  }
```

