## Diagrama de entidades diferidas (Lotes 2-4)

Para visualizar cómo el modelo crece:

```mermaid
%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#FFFBEB",
    "primaryBorderColor": "#FDE68A",
    "primaryTextColor": "#78350F",
    "lineColor": "#6B7280"
  }
}}%%

erDiagram

  Account ||--o{ Trip            : "has"
  Account ||--o{ Zone            : "defines"
  Account ||--o{ ServiceRecord   : "tracks"
  Account ||--o{ Document        : "stores"
  Account ||--o{ POI             : "places"
  Account ||--o{ AlarmRule       : "configures"
  Account ||--o{ KpiDailySnapshot : "rolls-up"
  Account ||--o{ User            : "members"
  Account ||--o{ Role            : "defines"

  Asset  ||--o{ Trip            : "executes"
  Asset  ||--o{ ServiceRecord   : "receives"
  Asset  ||--o{ Document        : "owns"

  Person ||--o{ Trip      : "drives"
  Person ||--o{ Document  : "owns"
  Person ||--o{ User      : "may link"

  Zone        ||--o{ Event      : "intersects"
  AlarmRule   ||--o{ Alarm      : "fires"
  Role        ||--o{ User       : "assigned"

  Trip {
    String   id
    String   assetId
    String   personId
    DateTime startedAt
    DateTime endedAt
    Float    distanceKm
    Float    avgSpeedKmh
    String   status
  }

  Zone {
    String id
    String accountId
    String name
    String type
    Json   geometry
    Json   rules
  }

  ServiceRecord {
    String   id
    String   assetId
    String   type
    DateTime performedAt
    Int      kmAtService
    Float    costAmount
  }

  Document {
    String   id
    String   accountId
    String   ownerType
    String   ownerId
    String   type
    String   number
    DateTime expiresAt
  }

  POI {
    String id
    String accountId
    String name
    Float  lat
    Float  lng
  }

  AlarmRule {
    String  id
    String  accountId
    String  scope
    String  scopeId
    Boolean enabled
    Json    trigger
    Json    action
  }

  KpiDailySnapshot {
    String   id
    String   accountId
    String   scope
    String   scopeId
    DateTime date
    Int      eventCount
    Int      alarmCount
    Float    kmDriven
    Int      safetyScore
  }

  User {
    String id
    String email
    String name
    String role
    String accountId
    String linkedPersonId
  }

  Role {
    String id
    String accountId
    String name
    Json   permissions
  }
```

