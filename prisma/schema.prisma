// ═══════════════════════════════════════════════════════════════
//  Maxtracker · Prisma Schema
//  ─────────────────────────────────────────────────────────────
//  Lote 1 scope: 9 entities to support the Seguridad vertical
//  slice (Dashboard D + Lista A + Libro B).
//
//  Decisions applied:
//    · ADR-000  Inaugural stack: Next.js 15 + Prisma 6 + SQLite
//    · ADR-001  One asset belongs to exactly ONE group (1:N)
//
//  Deliberately OUT of scope for Lote 1 (deferred to Lotes 2-4):
//    · Trip, Zone/Geofence, Document, ServiceRecord
//    · User/Auth (Auth0 integration)
//    · KpiDailySnapshot (pre-aggregation)
//    · AlarmRule (rule engine)
//    · POI (points of interest)
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection · usado por la app (alta concurrencia, conexiones cortas)
  url       = env("DATABASE_URL")
  // Conexión directa · usada por `prisma migrate` y `prisma db push`
  // (migrations no funcionan vía pooler · necesitan prepared statements)
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
//  ORGANIZATIONAL
// ═══════════════════════════════════════════════════════════════

/// The platform tenant (i.e. Maxtracker itself). A single row in
/// v1. Multi-tenant reseller scenarios are handled as additional
/// Organizations in a future lote.
model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  accounts  Account[]
  users     User[]
  createdAt DateTime  @default(now())
}

/// A client of the platform (e.g. a logistics company, a mining
/// operation, a delivery network). Everything the user sees is
/// scoped to an Account.
model Account {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String       @unique
  tier           Tier         @default(PRO)
  industry       String?
  groups         Group[]
  assets         Asset[]
  settings       AccountSettings?
  persons        Person[]
  alarms         Alarm[]
  assetDriverDays AssetDriverDay[]
  assetWeeklyStats AssetWeeklyStats[]
  users          User[]
  geofences      Geofence[]
  infractions    Infraction[]
  createdAt      DateTime     @default(now())
}

// ═══════════════════════════════════════════════════════════════
//  AccountSettings · 1:1 con Account
//  ─────────────────────────────────────────────────────────────
//  Settings configurables por el CLIENT_ADMIN. Una row por
//  Account · creada al provisionar el cliente con defaults LATAM.
// ═══════════════════════════════════════════════════════════════

model AccountSettings {
  id        String  @id @default(cuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // ─── Umbrales · velocidad ────────────────────────────────
  /// Velocidad máxima en zona urbana (km/h)
  speedLimitUrban       Int @default(60)
  /// Velocidad máxima en ruta nacional/provincial (km/h)
  speedLimitHighway     Int @default(100)
  /// Tolerancia · % por encima del límite antes de disparar alarma
  speedTolerancePercent Int @default(10)

  // ─── Umbrales · conducción agresiva ──────────────────────
  /// Frenada brusca · g-force mínimo · default LATAM 0.35g
  /// (US standard 0.45g · LATAM ajustado por estudios locales)
  harshBrakingThreshold     Float @default(0.35)
  /// Aceleración brusca · g-force mínimo
  harshAccelerationThreshold Float @default(0.35)
  /// Curva agresiva · g-force lateral mínimo
  harshCorneringThreshold    Float @default(0.40)

  // ─── Umbrales · ralentí ──────────────────────────────────
  /// Tiempo mínimo de ralentí para disparar alarma (segundos)
  idlingMinDuration Int @default(300)

  // ─── Umbrales · viajes ───────────────────────────────────
  /// Distancia mínima para considerar un viaje válido (km)
  tripMinDistanceKm Float @default(0.5)
  /// Duración mínima para considerar un viaje válido (segundos)
  tripMinDurationSec Int @default(60)

  // ─── Notificaciones a nivel cuenta ───────────────────────
  /// Email de contacto general del cliente para alertas críticas
  alertContactEmail String?
  /// Teléfono de contacto · capaz para SMS post-MVP
  alertContactPhone String?

  // ─── Integraciones (flexible · shape varía por provider) ──
  /// JSON con configuración de integraciones activas
  /// Ejemplo: { flespi: { token: "...", enabled: true }, ... }
  integrations Json @default("{}")

  // ─── Plan extras (flexible) ──────────────────────────────
  /// Features adicionales habilitados manualmente fuera del tier
  /// Ejemplo: { extraVehicles: 50, customReports: true }
  planOverrides Json @default("{}")

  // ─── Audit ───────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum Tier {
  BASE
  PRO
  ENTERPRISE
}

/// Logical grouping of assets within an Account. Two-level
/// hierarchy supported via self-relation (memory: max 2 niveles,
/// extensible in v2). An Asset belongs to at most one Group
/// directly (ADR-001).
model Group {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  parentId  String?
  parent    Group?   @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  Group[]  @relation("GroupHierarchy")
  name      String
  assets    Asset[]
  createdAt DateTime @default(now())

  @@index([accountId])
}

// ═══════════════════════════════════════════════════════════════
//  MONITORED OBJECT
// ═══════════════════════════════════════════════════════════════

/// The thing being monitored. Mobile (vehicle, machine) or fixed
/// (silo, elevator, refrigerator unit).
model Asset {
  id              String       @id @default(cuid())
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])
  /// ADR-001: nullable FK, 1:N cardinality.
  groupId         String?
  group           Group?       @relation(fields: [groupId], references: [id])
  name            String
  plate           String?      @unique
  vin             String?      @unique
  mobilityType    MobilityType @default(MOBILE)
  /// Used by the live tracking map to pick an icon when the
  /// "icons by type" view option is enabled. Falls back to the
  /// generic shape if GENERIC.
  vehicleType     VehicleType  @default(LIVIANO)
  make            String?
  model           String?
  year            Int?
  /// Lectura del odómetro al momento del alta (km). El kilometraje
  /// "actual" se deriva sumando los Trips posteriores. Permite
  /// planes de mantenimiento por kilómetros sin perder el histórico
  /// previo a Maxtracker.
  initialOdometerKm Int?
  status          AssetStatus  @default(IDLE)
  currentDriverId String?
  currentDriver   Person?      @relation("CurrentDriver", fields: [currentDriverId], references: [id])
  devices         Device[]
  positions       Position[]
  livePosition    LivePosition?
  trips           Trip[]
  events          Event[]
  alarms          Alarm[]
  assetDriverDays AssetDriverDay[]
  weeklyStats     AssetWeeklyStats[]
  infractions     Infraction[]
  createdAt       DateTime     @default(now())

  @@index([accountId, status])
  @@index([groupId])
}

enum MobilityType {
  MOBILE
  FIXED
}

/// Categorización de vehículos alineada con Ley Nacional de
/// Tránsito 24.449 art. 51 + tipos relevantes para Maxtracker.
/// Cada categoría tiene velocidades máximas distintas en la
/// tabla del módulo Conducción (ver src/lib/conduccion/vmax-table.ts).
///
/// S4-L3a · migración desde el enum previo (CAR/MOTORCYCLE/TRUCK/...)
enum VehicleType {
  /// Motocicleta · 110 ruta / 130 autopista
  MOTOCICLETA
  /// Auto particular · 110 ruta / 130 autopista
  LIVIANO
  /// Pick-up / camioneta uso comercial · idem liviano por ley
  UTILITARIO
  /// Microbús, ómnibus, casa rodante motorizada · 90 ruta / 100 autopista
  PASAJEROS
  /// Camión solo, sin acoplado · 90 ruta / 100 autopista
  CAMION_LIVIANO
  /// Camión con acoplado/semi-remolque · 80 ruta / 80 autopista
  CAMION_PESADO
  /// Transporte de sustancias peligrosas · 80 ruta / 80 autopista
  SUSTANCIAS_PELIGROSAS
  /// Maquinaria vial · velocidad propia restringida
  MAQUINA_VIAL
  /// Asset fijo (silo, refrigerador, generador) · sin score de conducción
  ASSET_FIJO
}

enum AssetStatus {
  MOVING
  IDLE
  STOPPED
  OFFLINE
  MAINTENANCE
}

/// Physical IoT hardware attached to an Asset. An asset can have
/// multiple devices simultaneously; exactly one is marked as
/// primary for position reporting.
model Device {
  id          String    @id @default(cuid())

  /// Asset al que está instalado el dispositivo. NULL cuando el
  /// device está en stock, en reparación o dado de baja.
  assetId     String?
  asset       Asset?    @relation(fields: [assetId], references: [id])

  imei        String    @unique
  /// Número de serie del fabricante (puede coexistir con IMEI).
  /// No todos los vendors lo proveen.
  serialNumber String?

  /// Marca del dispositivo. Limitamos a un set conocido para
  /// poder mantener integraciones (codecs, configs, comandos).
  /// "OTHER" deja espacio para casos esporádicos.
  vendor      DeviceVendor
  model       String

  /// Versión de firmware actualmente cargada · útil para tracking
  /// de updates y troubleshooting de bugs específicos por versión.
  firmwareVersion String?

  /// Estado en el ciclo de vida del dispositivo · ver DeviceStatus
  status      DeviceStatus @default(STOCK)

  /// Si está marcado, es el dispositivo principal del Asset
  /// (cuando un Asset tiene múltiples devices, ej · GPS + cámara).
  isPrimary   Boolean   @default(false)

  /// SIM card insertada en el dispositivo. NULL cuando el device
  /// no tiene SIM (recién recibido, en stock sin SIM provista, o
  /// en reparación con la SIM removida). La relación es 1-1 vía
  /// @unique en simId · una SIM no puede estar en dos devices.
  simId       String?   @unique
  sim         Sim?      @relation(fields: [simId], references: [id])

  lastSeenAt  DateTime?
  installedAt DateTime  @default(now())

  @@index([assetId])
  @@index([status])
}

enum DeviceVendor {
  TELTONIKA
  QUECLINK
  CONCOX
  OTHER
}

enum DeviceStatus {
  /// Recién recibido, no instalado en ningún asset todavía.
  STOCK
  /// Instalado y operando en un Asset.
  INSTALLED
  /// Removido por falla, esperando service o reemplazo.
  IN_REPAIR
  /// Vida útil terminada · no se reinstala.
  DECOMMISSIONED
}

// ═══════════════════════════════════════════════════════════════
//  SIM CARDS
// ═══════════════════════════════════════════════════════════════

/// SIM card de datos asignada (potencialmente) a un Device. La
/// relación SIM ↔ Device vive en `Device.simId` (1-1). Una SIM
/// puede estar en stock (sin device) o asignada (en un device).
model Sim {
  id           String    @id @default(cuid())

  /// Integrated Circuit Card ID · 19-20 dígitos numéricos.
  /// Es el identificador único físico de la SIM, impreso en
  /// el plástico y leído por el modem del Device.
  iccid        String    @unique

  /// Número telefónico (MSISDN) asignado por el carrier. No
  /// siempre se conoce · algunas APIs IoT no lo exponen.
  phoneNumber  String?

  /// IMSI · International Mobile Subscriber Identity. Usado para
  /// algunos provisioning automáticos · opcional para el demo.
  imsi         String?

  /// Carrier comercial · acotado a los principales del Cono Sur.
  /// "OTHER" cubre carriers regionales (Bitel, Tigo, etc.).
  carrier      Carrier

  /// Access Point Name · necesario para que el modem se conecte
  /// a la red de datos. Cada carrier tiene su APN específico.
  /// Ej · "internet.movistar.com.ar"
  apn          String

  /// Cuota mensual de datos en MB. Los planes IoT típicos van
  /// de 10 MB (telemetría básica) a 500 MB (cámaras + video).
  dataPlanMb   Int       @default(50)

  status       SimStatus @default(STOCK)

  /// Backref · una SIM puede estar dentro de un Device. La FK
  /// real vive en Device.simId (con @unique). Acá es el otro
  /// lado de la relación, opcional.
  device       Device?

  activatedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([carrier])
}

enum Carrier {
  MOVISTAR
  CLARO
  PERSONAL
  ENTEL
  OTHER
}

enum SimStatus {
  /// Recibida del carrier, no asignada a ningún device.
  STOCK
  /// Operando dentro de un device · transmitiendo datos.
  ACTIVE
  /// Pausada por el carrier (deuda, cambio de plan, robo).
  /// El device queda offline mientras dura la suspensión.
  SUSPENDED
  /// Dada de baja · no se reactiva. Liberable del device.
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════
//  PEOPLE
// ═══════════════════════════════════════════════════════════════

/// Drivers and operators. Different from the system User (auth)
/// entity — those come in a later lote when we wire Auth0.
model Person {
  id               String           @id @default(cuid())
  accountId        String
  account          Account          @relation(fields: [accountId], references: [id])
  firstName        String
  lastName         String
  document         String?
  licenseExpiresAt DateTime?
  hiredAt          DateTime?
  /// Rolling safety score 0-100, derived from Event history.
  /// Seeded statically in Lote 1; derived dynamically in Lote 3.
  safetyScore      Int              @default(75)
  drivenAssets     Asset[]          @relation("CurrentDriver")
  events           Event[]
  alarms           Alarm[]
  trips            Trip[]
  assetDriverDays  AssetDriverDay[]
  infractions      Infraction[]

  @@index([accountId])
}

// ═══════════════════════════════════════════════════════════════
//  REPORTING · pre-aggregated tables
//  ─────────────────────────────────────────────────────────────
//  These tables exist to keep the UI off of the raw Position
//  hypertable. In production they're populated by a stream
//  processor (or a periodic batch job) over the same window.
//  In the demo they're populated at seed time once.
// ═══════════════════════════════════════════════════════════════

/// Per-asset latest known position. Conceptually a key-value
/// store: `assetId → last position`. In production this is an
/// in-memory store (e.g. Redis or a process-local map) fed by
/// the TCP ingester. Modeled here as a regular table so the
/// demo can serve it through Prisma without changing the UI
/// when the ingester is wired up.
///
/// Read by:
///   · /gestion/vehiculos · listado · columna "Velocidad
///     instantánea" (E6-A)
///   · /seguimiento/mapa · markers de la flota (futuro)
///
/// Populated in seed from the most recent Position row of each
/// asset. In production it's overwritten by every fix the
/// ingester receives.
model LivePosition {
  assetId    String   @id
  asset      Asset    @relation(fields: [assetId], references: [id])
  recordedAt DateTime
  lat        Float
  lng        Float
  speedKmh   Float
  heading    Int?
  ignition   Boolean
  updatedAt  DateTime @default(now())

  /// S2-L3 · canData del último ping · espejo del Position más
  /// reciente para evitar JOIN al consultar el "ahora" del vehículo.
  canData    Json?

  @@index([recordedAt])
  @@index([speedKmh])
}

/// Detected trip · ignition-bounded segment of an asset's
/// movement. Persisted at seed time (in production: emitted by
/// the trip-detection stream processor on top of Position).
///
/// Read by:
///   · /seguimiento/viajes (E5-B antes; F1 ahora · sub-segundo)
///   · /gestion/vehiculos/[id] tab Histórico (filtra por assetId)
///   · AssetDriverDay rollup (lee Trips, no Positions)
///
/// `polylineJson` is the simplified geometry (~80 points) used by
/// the routes overlay. SQLite has no Json type, so it's a string;
/// Postgres in prod uses Jsonb.
model Trip {
  id                     String   @id @default(cuid())
  assetId                String
  asset                  Asset    @relation(fields: [assetId], references: [id])
  /// Driver associated with the trip · resolved at trip-creation
  /// time (currentDriver at startedAt). Null if asset had no driver.
  personId               String?
  person                 Person?  @relation(fields: [personId], references: [id])
  startedAt              DateTime
  endedAt                DateTime
  durationMs             Int
  distanceKm             Float
  avgSpeedKmh            Float
  maxSpeedKmh            Float
  idleMs                 Int
  startLat               Float
  startLng               Float
  endLat                 Float
  endLng                 Float
  positionCount          Int
  /// JSON-encoded `[[lat, lng], …]` · ~80 points after Douglas-
  /// Peucker-style decimation. Used by getTripRoutes overlays.
  polylineJson           String
  eventCount             Int      @default(0)
  highSeverityEventCount Int      @default(0)
  createdAt              DateTime @default(now())

  @@index([startedAt])
  @@index([assetId, startedAt])
  @@index([personId, startedAt])
}

/// Daily aggregation: who drove which asset on which day, plus
/// distance / active time / trip count for that pairing. One row
/// per (asset, person, AR-local day) with at least one trip.
///
/// Read by:
///   · /gestion/vehiculos/[id] · tab Conductor (E5-A) · "who drove
///     this vehicle and when"
///   · /gestion/conductores/[id] · tab Vehículos (E7 · espejo) ·
///     "which vehicles did this driver use"
///   · Driver-asset utilization reports (future)
///
/// Populated in seed by detecting trips from Position once and
/// rolling them up. In production this is the output of a daily
/// batch job over the trip table.
model AssetDriverDay {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  /// AR-local day boundary. Stored as the UTC instant that
  /// represents 00:00:00 AR-local of the day (i.e. 03:00:00 UTC).
  day         DateTime
  distanceKm  Float
  /// Active driving minutes (ignition-on segments capped at 5 min
  /// per gap to avoid overcounting device dropouts).
  activeMin   Int
  tripCount   Int
  /// First trip start of the day (for "primer toque").
  firstTripAt DateTime
  /// Last trip end of the day (for "último toque").
  lastTripAt  DateTime
  createdAt   DateTime @default(now())

  @@unique([assetId, personId, day])
  @@index([assetId, day])
  @@index([personId, day])
  @@index([accountId, day])
}

/// Weekly aggregate per asset · used by the Actividad module
/// (Resumen, Comparativas, Reportes) to compute deltas vs. the
/// asset's own historical baseline and to detect outliers.
///
/// Generated by a batch job at week-close. Reads from
/// AssetDriverDay + Event + Trip · never from Position.
///
/// `weekStart` is the AR-local Monday 00:00 of the week, stored
/// as the UTC instant (i.e. 03:00:00 UTC of that Monday).
///
/// All time fields are minutes. distanceKm is float because we
/// inherit fractional km from AssetDriverDay rollups.
model AssetWeeklyStats {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id])
  weekStart       DateTime
  /// Total km in the week (sum across all drivers of the asset)
  distanceKm      Float
  /// Active driving minutes
  activeMin       Int
  /// Idle minutes (ignition on, no movement)
  idleMin         Int
  /// Distinct days with at least one trip
  activeDays      Int
  tripCount       Int
  /// Total events generated in the week (any severity)
  eventCount      Int
  /// Events with severity HIGH or CRITICAL
  highEventCount  Int
  /// Speeding-type events specifically (counts toward "infracciones")
  speedingCount   Int
  /// Peak speed reached during the week (km/h)
  maxSpeedKmh     Float
  /// Estimated fuel consumption in liters (placeholder · refined
  /// when we add real fuel sensor data; today derived from
  /// activeMin × consumption coefficient by vehicleType)
  fuelLiters      Float
  createdAt       DateTime @default(now())

  @@unique([assetId, weekStart])
  @@index([assetId, weekStart])
  @@index([accountId, weekStart])
}

// ═══════════════════════════════════════════════════════════════
//  TELEMETRY
// ═══════════════════════════════════════════════════════════════

/// Raw GPS position record. In production these land on a
/// TimescaleDB hypertable; in SQLite they live as a plain table.
/// recordedAt = device time, receivedAt = server ingest time.
/// Backfill scenarios make these diverge (memory: backfill_flag).
model Position {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  recordedAt DateTime
  receivedAt DateTime @default(now())
  lat        Float
  lng        Float
  speedKmh   Float
  heading    Int?
  ignition   Boolean  @default(true)

  /// S2-L3 · Datos del bus CAN del momento del ping · null si el
  /// dispositivo no reporta CAN (FMB920/Legacy) o si todavía no
  /// llegó el primer parser de Flespi. Shape definido en
  /// src/lib/mock-can/types.ts (interface CanSnapshot) · cuando
  /// llegue el ingestor real, este campo se persiste igual.
  canData    Json?

  /// S4-L3a · Tipo de vía inferido del entorno OSM al momento del
  /// ping. Null si no se pudo determinar (zona sin datos OSM o
  /// ingestor sin lookup). Usado por el resolver de vmax para
  /// aplicar la tabla Ley 24.449 sin recomputar OSM en cada query.
  /// En seed se asigna heurísticamente desde la velocidad del segmento.
  roadType   RoadType?

  @@index([assetId, recordedAt])
  @@unique([assetId, recordedAt])
}

/// Discrete observation derived from telemetry (harsh braking,
/// speeding threshold crossed, ignition change, etc.). Feeds KPIs
/// and may escalate into an Alarm.
model Event {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  personId   String?
  person     Person?   @relation(fields: [personId], references: [id])
  type       EventType
  severity   Severity  @default(MEDIUM)
  occurredAt DateTime
  lat        Float?
  lng        Float?
  speedKmh   Float?
  /// Stringified JSON (SQLite has no Jsonb). Postgres migration
  /// will convert this field to Json type.
  metadata   String?

  @@index([assetId, occurredAt])
  @@index([personId, occurredAt])
}

enum EventType {
  // ─── Conducción · driver behavior ──────────────────
  HARSH_BRAKING
  HARSH_ACCELERATION
  HARSH_CORNERING
  SPEEDING
  IDLING
  IGNITION_ON
  IGNITION_OFF

  // ─── Seguridad · threats & sabotage ────────────────
  PANIC_BUTTON
  UNAUTHORIZED_USE
  DOOR_OPEN
  SIDE_DOOR_OPEN
  CARGO_DOOR_OPEN
  TRAILER_DETACH
  GPS_DISCONNECT
  POWER_DISCONNECT
  JAMMING_DETECTED
  SABOTAGE

  // ─── Transversales ──────────────────────────────────
  GEOFENCE_ENTRY
  GEOFENCE_EXIT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ═══════════════════════════════════════════════════════════════
//  ALARMS
// ═══════════════════════════════════════════════════════════════

/// Escalated event requiring human attention. Lifecycle:
/// OPEN → ATTENDED → CLOSED (or DISMISSED). Rule engine for
/// auto-escalation comes in Lote 3.
///
/// `domain` separates Conducción (driver behavior) from
/// Seguridad (threats / sabotage). Each module shows only
/// alarms of its own domain.
model Alarm {
  id          String      @id @default(cuid())
  accountId   String
  account     Account     @relation(fields: [accountId], references: [id])
  assetId     String
  asset       Asset       @relation(fields: [assetId], references: [id])
  personId    String?
  person      Person?     @relation(fields: [personId], references: [id])
  domain      AlarmDomain
  type        AlarmType
  severity    Severity
  status      AlarmStatus @default(OPEN)
  triggeredAt DateTime
  attendedAt  DateTime?
  closedAt    DateTime?
  lat         Float?
  lng         Float?
  notes       String?

  @@index([accountId, domain, status, triggeredAt])
  @@index([assetId, triggeredAt])
}

enum AlarmDomain {
  CONDUCCION
  SEGURIDAD
}

enum AlarmType {
  // ─── Conducción ──────────────────
  HARSH_DRIVING_PATTERN
  SPEEDING_CRITICAL
  RECKLESS_BEHAVIOR

  // ─── Seguridad ───────────────────
  PANIC
  UNAUTHORIZED_USE
  SABOTAGE
  GPS_DISCONNECT
  POWER_DISCONNECT
  JAMMING
  TRAILER_DETACH
  CARGO_BREACH
  DOOR_BREACH
  GEOFENCE_BREACH_CRITICAL

  // ─── Transversales ───────────────
  DEVICE_OFFLINE
}

enum AlarmStatus {
  OPEN
  ATTENDED
  CLOSED
  DISMISSED
}

// ═══════════════════════════════════════════════════════════════
//  AUTH & PERMISSIONS
//  ─────────────────────────────────────────────────────────────
//  Lote F1 · fundamentos para Configuración personal y Backoffice.
//
//  Auth real (Auth0) viene en v1.1+. Por ahora la sesión es
//  simulada con una cookie "mxt-demo-user-id" + selector de
//  identidad en el topbar. passwordHash queda como columna pero
//  no se valida en demo.
//
//  Multi-tenancy:
//    · Super admin / Maxtracker admin · accountId = null (cross)
//    · Client admin / Operator · accountId set (scoped)
// ═══════════════════════════════════════════════════════════════

model User {
  id              String    @id @default(cuid())
  email           String    @unique

  /// ID en auth.users de Supabase. Null si el user todavía
  /// no fue provisionado en Supabase Auth (caso seed inicial).
  supabaseAuthId String?     @unique
  firstName       String
  lastName        String
  phone           String?
  documentNumber  String?

  /// Dummy en demo · auth real (Auth0) en v1.1+
  passwordHash    String
  status          UserStatus @default(ACTIVE)

  // ─── Tenant scoping ──────────────────────────────────────
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  /// Null si Super admin o Admin Maxtracker (cross-account).
  /// Set si Admin de Cliente u Operador (scoped a un Account).
  accountId       String?
  account         Account?  @relation(fields: [accountId], references: [id])

  // ─── Role assignment ─────────────────────────────────────
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id])

  // ─── Personal preferences (Configuración) ────────────────
  language             String   @default("es-AR")
  theme                Theme    @default(LIGHT)
  notifyAlarmHighCrit  Boolean  @default(true)
  notifyScoreDrop      Boolean  @default(true)
  notifyBoletinClosed  Boolean  @default(true)
  notifyCriticalEvent  Boolean  @default(true)

  // ─── S1-L8 · feedback widget · relación inversa ───────────
  feedbacks            Feedback[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

/// Perfil de permisos · 4 builtin (SUPER_ADMIN, MAXTRACKER_ADMIN,
/// CLIENT_ADMIN, OPERATOR) + posibles personalizados a futuro
/// (isBuiltin = false).
model Profile {
  id          String    @id @default(cuid())
  systemKey   ProfileKey @unique
  /// Nombre editable por admin · "Operador" puede renombrarse a
  /// "Despachador" sin cambiar systemKey
  nameLabel   String
  description String?

  /// Permisos por módulo · JSON con shape PermissionsMap definido
  /// en src/lib/permissions.ts. Editable desde /admin/perfiles.
  permissions Json

  users       User[]
  isBuiltin   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ProfileKey {
  SUPER_ADMIN
  MAXTRACKER_ADMIN
  CLIENT_ADMIN
  OPERATOR
}

// ═══════════════════════════════════════════════════════════════
//  BoletinSnapshot · S1-L7 cron-scaffold
//  ─────────────────────────────────────────────────────────────
//  Snapshot pre-computado del boletín mensual de un account.
//  Generado por el cron diario de Vercel · vive como caché para
//  que la página del boletín no recompute on-demand.
//
//  Period format: YYYY-MM (e.g. "2026-04")
//
//  Política de regeneración:
//    · El cron diario actualiza el snapshot del MES EN CURSO.
//    · Snapshots de meses pasados se regeneran solo si se borran
//      manualmente (o vía endpoint POST /api/cron/...).
//    · La page hace fallback a cómputo on-demand si no hay snapshot.
// ═══════════════════════════════════════════════════════════════
model BoletinSnapshot {
  id          String   @id @default(cuid())
  /// "YYYY-MM" del mes que el snapshot representa
  period      String
  /// null = cross-tenant (SA/MA preview) · de lo contrario, accountId del cliente
  accountId   String?
  /// Payload completo del boletín · shape BoletinExportPayload
  payload     Json
  generatedAt DateTime @default(now())
  /// Identifica quién/qué generó este snapshot · "cron" para Vercel cron,
  /// "manual" para invocación ad-hoc, "onDemand" para fallback de la page
  source      String   @default("cron")

  @@unique([period, accountId])
  @@index([generatedAt])
}

// ═══════════════════════════════════════════════════════════════
//  Feedback · S1-L8 feedback-widget
//  ─────────────────────────────────────────────────────────────
//  Captura feedback de testers y usuarios beta · widget flotante
//  global en /(product)/* envía POSTs a /api/feedback.
//
//  Status workflow:
//    NEW (default) → REVIEWED (admin lo leyó) → CLOSED (resuelto)
//
//  PII: el message es texto libre del user · puede contener
//  cualquier cosa. NO se exporta a analytics · solo a admin DB.
// ═══════════════════════════════════════════════════════════════
model Feedback {
  id          String           @id @default(cuid())
  /// Account del user · null si user anónimo (no debería pasar en prod)
  accountId   String?
  /// User que envió · null en demo mode sin auth
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  /// Categoría del feedback
  category    FeedbackCategory @default(OTHER)
  /// Mensaje del user · texto libre
  message     String
  /// URL donde estaba el user · ej. "/objeto/vehiculo/abc123?m=resumen"
  pageUrl     String
  /// User agent del browser · ayuda a identificar bugs cross-browser
  userAgent   String
  /// "1920x1080" · útil para bugs de layout
  viewport    String?
  /// Estado de gestión · cambiable por admin
  status      FeedbackStatus   @default(NEW)
  createdAt   DateTime         @default(now())
  /// Cuándo el admin marcó como revisado · null si NEW
  reviewedAt  DateTime?
  /// Notas internas del admin · no visibles para el user
  adminNotes  String?

  @@index([status, createdAt])
  @@index([accountId, createdAt])
}

enum FeedbackCategory {
  BUG
  FEATURE
  OTHER
}

enum FeedbackStatus {
  NEW
  REVIEWED
  CLOSED
}

// ═══════════════════════════════════════════════════════════════
//  CONDUCCIÓN · S4-L3a
//  ─────────────────────────────────────────────────────────────
//  Modelo de datos para el módulo Conducción, basado en la
//  metodología Geotab Driver Safety Scorecard adaptada a LATAM:
//    · Solo speeding en MVP (los acelerómetros vienen en S5+)
//    · Infracción = secuencia de excesos consecutivos > 2 min
//    · Vmax aplicable según Ley Nacional de Tránsito 24.449
//    · Override por Geofence para zonas especiales (petroleras,
//      mineras, predios cliente, caminos internos, etc.)
//
//  Una infracción NO es un evento puntual · es una agregación
//  temporal con polilínea, pico de velocidad, distancia recorrida
//  en exceso y calificación L/M/G.
// ═══════════════════════════════════════════════════════════════

/// Tipo de vía inferido del entorno OSM. Determina la velocidad
/// máxima aplicable cuando no hay tag `maxspeed` explícito ni
/// override de geofence. Mapeo en src/lib/conduccion/vmax-table.ts.
enum RoadType {
  /// Calle urbana · 40 km/h todos los vehículos (Ley 24.449)
  URBANO_CALLE
  /// Avenida urbana · 60 km/h todos los vehículos
  URBANO_AVENIDA
  /// Ruta convencional · 110 livianos / 90 pasajeros / 80 pesados
  RURAL
  /// Semiautopista · 120 livianos / 90 pasajeros / 80 pesados
  SEMIAUTOPISTA
  /// Autopista · 130 livianos / 100 pasajeros / 80 pesados
  AUTOPISTA
  /// Camino rural no pavimentado · 60 km/h default LATAM
  CAMINO_RURAL
  /// Sin datos OSM · aplica vmax conservador del fallback
  DESCONOCIDO
}

/// Polígono geográfico que aplica reglas particulares al
/// asset que lo atraviesa. Cubre desde geocercas de seguridad
/// (entry/exit alarms · ya existentes como EventType) hasta
/// overrides de velocidad máxima para zonas especiales que la
/// ley nacional no contempla (yacimientos, minas, predios,
/// caminos internos).
///
/// El polígono se almacena como GeoJSON stringified · cuando se
/// migre a PostGIS, este campo se reemplaza por geometry(Polygon).
/// Para "caminos lineales" (ruta interna, camino petrolero) se
/// usa un polígono fino (buffer del trazado, ej. 50m a cada lado).
model Geofence {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])

  name        String
  description String?

  /// GeoJSON Polygon stringified · ej. {"type":"Polygon","coordinates":[[[...]]]}
  polygonGeoJson    String

  /// Categoría reutilizable para agrupar geocercas con reglas
  /// comunes (UI puede filtrar/colorear por categoría).
  category    GeofenceCategory?

  /// Override de vmax por VehicleType al cruzar el polígono.
  /// Stringified Record<VehicleType, number>. Ej:
  ///   {"LIVIANO":40,"CAMION_PESADO":30,"MAQUINA_VIAL":20}
  /// null = la geocerca solo dispara entry/exit events,
  /// sin afectar el cálculo de infracciones por velocidad.
  vmaxOverrideJson  String?

  /// Para resolver conflicto cuando un punto está adentro de
  /// múltiples geocercas con override. Mayor priority gana.
  priority    Int      @default(0)

  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([accountId, active])
}

enum GeofenceCategory {
  /// Yacimiento / instalación petrolera principal
  PETROLERA_PRIMARIA
  /// Caminos secundarios dentro del área petrolera
  PETROLERA_SECUNDARIA
  /// Mina / yacimiento minero
  MINERA_INTERNA
  /// Predio / depósito / planta del cliente
  PREDIO_CLIENTE
  /// Camino interno (lineal, modelado como buffer fino)
  CAMINO_INTERNO
  /// Zona escolar / cruces críticos · post-MVP
  ZONA_ESCOLAR
  OTROS
}

/// Infracción de velocidad · agregación temporal de excesos
/// consecutivos sostenidos durante más del umbral mínimo (2 min).
///
/// El cálculo es server-side desde Position vía
/// src/lib/conduccion/compute-infractions.ts. Los eventos
/// puntuales (cada Position con vel > vmax) NO se materializan
/// como Event para evitar inflar la tabla de eventos.
///
/// Status ACTIVE entran al score del conductor.
/// Status DISCARDED quedan en BD para auditoría pero no afectan
/// score · el admin puede descartar por error técnico (límite
/// incorrecto, GPS malo, vehículo con inmunidad, etc.).
model Infraction {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id])
  driverId        String?
  driver          Person?  @relation(fields: [driverId], references: [id])

  /// Inicio del primer sample en exceso del segmento
  startedAt       DateTime
  /// Fin del último sample en exceso del segmento
  endedAt         DateTime
  /// Duración del segmento en segundos · siempre >= 120 (umbral)
  durationSec     Int

  /// Velocidad máxima aplicable según resolveVmax (la que estaba
  /// vigente al momento de la infracción · snapshot, no se recalcula)
  vmaxKmh         Int
  /// Pico de velocidad alcanzado durante el segmento
  peakSpeedKmh    Float
  /// peakSpeedKmh - vmaxKmh · define la severity (L/M/G)
  maxExcessKmh    Float
  /// Distancia recorrida en exceso · suma de geo-distance entre
  /// samples del segmento (entra al Violation Percentage Method)
  distanceMeters  Float

  /// LEVE | MEDIA | GRAVE según maxExcessKmh
  /// (≤9 LEVE · 10-17 MEDIA · ≥18 GRAVE · configurable post-MVP)
  severity        InfractionSeverity
  /// Snapshot del tipo de vehículo al momento de la infracción
  vehicleType     VehicleType
  /// Snapshot del tipo de vía al momento de la infracción
  roadType        RoadType

  startLat        Float
  startLon        Float
  startAddress    String?
  endLat          Float
  endLon          Float
  endAddress      String?

  /// JSON stringified · array de samples del segmento para
  /// reconstruir polilínea + curva velocidad/tiempo en el
  /// recibo PDF. Shape: [[lat, lon, isoTimestamp, speedKmh], ...]
  trackJson       String

  /// ACTIVE entra al score · DISCARDED queda en BD pero no
  /// afecta score (audit trail de descartes manuales).
  status          InfractionStatus @default(ACTIVE)
  /// Razón del descarte · solo populado cuando status=DISCARDED
  discardReason   DiscardReason?
  /// User que descartó · solo populado cuando status=DISCARDED
  discardedById   String?
  discardedAt     DateTime?

  createdAt       DateTime @default(now())

  @@index([accountId, startedAt])
  @@index([assetId, startedAt])
  @@index([driverId, startedAt])
}

enum InfractionSeverity {
  LEVE
  MEDIA
  GRAVE
}

enum InfractionStatus {
  ACTIVE
  DISCARDED
}

enum DiscardReason {
  /// El vmax aplicado no era el correcto (error de OSM, geofence faltante, etc.)
  WRONG_SPEED_LIMIT
  /// El tipo de vía inferido no coincide con la realidad
  WRONG_ROAD_TYPE
  /// Las posiciones del segmento eran ruido GPS (drift, salto, etc.)
  POOR_GPS_QUALITY
  /// Vehículo o conductor con inmunidad operacional (servicios de emergencia, etc.)
  DRIVER_VEHICLE_IMMUNITY
}
