# ═══════════════════════════════════════════════════════════════
#  Maxtracker · variables de entorno
#  ─────────────────────────────────────────────────────────────
#  Copiar a .env.local y completar valores reales.
#  No comitear .env.local · ya está en .gitignore.
# ═══════════════════════════════════════════════════════════════

# DB · SQLite local
DATABASE_URL="file:./prisma/dev.db"

# ─── Ingestion · webhook flespi ─────────────────────────────
# Token compartido entre tu app y el stream HTTPS de flespi.
# Generá uno aleatorio: openssl rand -base64 32
# En el panel de flespi (Streams → tu stream → Custom headers)
# agregar:    X-Flespi-Token: <mismo valor>
FLESPI_INGEST_TOKEN=cambiar_por_un_token_aleatorio_largo
