# ═══════════════════════════════════════════════════════════════
#  Maxtracker · Variables de entorno
#  ─────────────────────────────────────────────────────────────
#  Copiar este archivo a `.env.local` y completar los valores.
#  El `.env.local` está gitignored · no se commitea nunca.
# ═══════════════════════════════════════════════════════════════

# ── Database (Supabase · Postgres) ─────────────────────────────
#
# Estas dos URLs vienen del dashboard de Supabase:
#   Settings → Database → Connection string
#
# DATABASE_URL · "Transaction" mode · puerto 6543
#   La app usa esto en runtime · pooler maneja muchas conexiones
#   cortas con eficiencia.
#
# DIRECT_URL · "Session" mode · puerto 5432
#   Prisma migrate y db push lo usan · necesita prepared statements
#   que el pooler de transaction mode no soporta.
#
# IMPORTANTE: la password va URL-encoded en la URL · si tu password
# tiene `@`, `#`, `?`, etc., reemplazar con %40, %23, %3F, etc.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"


# ── Flespi ingestion ──────────────────────────────────────────
#
# Token Bearer que flespi (u otro reenvío) envía como header
# `X-Flespi-Token` o `Authorization: Bearer <token>`.
#
# Generar con: openssl rand -base64 32
FLESPI_INGEST_TOKEN="cambiar-por-un-token-fuerte"


# ── Supabase (para Auth · viene en H2) ─────────────────────────
#
# Estos los vamos a usar en H2 cuando integremos Supabase Auth.
# Por ahora opcional · dejar comentados.
#
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."        # solo backend, NEVER expose


# ── Modo Auth (transition · viene en H2) ───────────────────────
#
# AUTH_MODE=demo       · cookie demo (default · solo dev local)
# AUTH_MODE=supabase   · sesión real con Supabase Auth (prod)
#
# AUTH_MODE="demo"
