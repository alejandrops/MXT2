{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "regions": ["gru1"],
  "functions": {
    "src/app/api/ingest/flespi/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ingest/flespi/metrics/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/generate-boletines/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/generate-driver-boletines/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/generate-fleet-boletines/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-boletines",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-driver-boletines",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/generate-fleet-boletines",
      "schedule": "30 6 * * *"
    }
  ]
}
