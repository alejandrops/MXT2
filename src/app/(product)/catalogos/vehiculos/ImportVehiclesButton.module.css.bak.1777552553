.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  background: #FFFFFF;
  color: #374151;
  border: 1px solid #D1D5DB;
  border-radius: 4px;
  font-family: var(--f);
  font-size: 12.5px;
  font-weight: 500;
  cursor: pointer;
  transition: all 60ms;
  white-space: nowrap;
}

.btn:hover {
  background: #F9FAFB;
  border-color: #9CA3AF;
  color: #111827;
}
